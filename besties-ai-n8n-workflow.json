    {
      "parameters": {
        "jsCode": "const queryData = $input.first()?.json?.query || {};\nconst sessionFilter = queryData.session || '';\nconst limitParam = parseInt(queryData.limit || '20', 10);\n\nconst rows = $input.all().map(r => r.json);\n\nconst filtered = sessionFilter\n  ? rows.filter(r => r['Session ID'] === sessionFilter)\n  : rows;\n\n// ข้อมูลโครงการล่วงหน้า (project_brief / workshop)\nconst briefRows = filtered.filter(r =>\n  r['Type'] === 'project_brief' || r['Type'] === 'workshop'\n);\nconst briefText = briefRows.map(r => r['Text']).join('\\n');\n\n// การนำเสนอสด\nconst sttOnly = filtered\n  .filter(r => r['Type'] === 'stt')\n  .slice(-limitParam);\nconst sttText = sttOnly.map(r => r['Text']).join('\\n');\n\nconst contextText =\n  (briefText ? '[ข้อมูลโครงการล่วงหน้า]\\n' + briefText + '\\n\\n' : '') +\n  (sttText  ? '[การนำเสนอสด]\\n' + sttText : '');\n\nreturn [{\n  json: {\n    ok: true,\n    count: filtered.length,\n    sttCount: sttOnly.length,\n    briefCount: briefRows.length,\n    session: sessionFilter || 'all',\n    contextText,\n    kb: filtered.map(r => ({\n      ts:      r['Timestamp'],\n      session: r['Session ID'],\n      type:    r['Type'],\n      text:    r['Text']\n    }))\n  }\n}];"
      },
